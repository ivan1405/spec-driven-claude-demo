# ---- Trello ----
# Get an API key + token at https://trello.com/power-ups/admin (create a Power-Up,
# then "API key" in the sidebar). Generate a token from the link shown next to the key,
# requesting read,write scope.
TRELLO_API_KEY=c5a83f4eb9dcdc623943b86b69ae2e36
TRELLO_TOKEN=ATTAbc220fddb663543b7232e4fff61f36bdaba5277c9e6e4d0235186061100518d870B6C343
# Optional: the default board the Trello MCP starts on (can be switched at runtime).
TRELLO_BOARD_ID=spec-driven-demo-claude-code

# ---- Jira / Atlassian ----
# The Atlassian Rovo MCP server uses interactive OAuth on first run — no token needed here.
# A browser window opens the first time you run Claude Code; approve access to your site.
# (If your org disables OAuth, switch to API-token auth — see README "Jira auth fallback".)

# ---- GitHub (for PR creation) ----
# PRs are created with the `gh` CLI, which has its own auth (`gh auth login`).
# Nothing required in this file.
