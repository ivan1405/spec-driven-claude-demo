{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "mcp__atlassian",
      "mcp__trello",
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "Bash(openspec:*)",
      "Bash(git:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)"
    ]
  }
}
